# .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
ai_venv/

# Django stuff:
*.log
*.pot
*.pyc
*.pyo
*.pyd
*.sqlite3
db.sqlite3

# Django migrations
*/migrations/*

# If you are using MySQL, PostgreSQL, or SQLite
*.db

# Media files
/media

# Static files
/static

# Jupyter Notebook
.ipynb_checkpoints

# VS Code
.vscode/

# Environments
.env
.env.*

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db